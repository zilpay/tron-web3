{
  "name": "@bearby/web3-tron",
  "version": "0.1.0",
  "description": "A Web3 provider for the Bearby wallet to interact with Tron-compatible chains.",
  "author": "Rinat lich666black@gmail.com",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nicola/web3-tron.git"
  },
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "dev": "bun build ./index.ts --outdir ./dist --target browser --format iife --no-minify",
    "build": "bun build index.ts --outdir ./dist --target browser --minify --sourcemap=none --format iife",
    "serve": "bun run build && bun server.ts",
    "check": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.9.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "bearby",
    "web3",
    "tron",
    "tronweb",
    "blockchain",
    "wallet"
  ],
  "dependencies": {
    "tronweb": "^6.2.2"
  }
}
